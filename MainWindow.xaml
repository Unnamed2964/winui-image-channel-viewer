<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="image_channel_viewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:image_channel_viewer"
    mc:Ignorable="d"
    Title="Image Channel Viewer">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <!-- 8epx between control and header, 32 + 8 + 8 = 48 -->
                <RowDefinition Height="48"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <!-- "24epx: Spacing between content sections." specify in the "WinUI 3 Gallery" App -->
                <StackPanel Orientation="Horizontal" Margin="12,0" Spacing="24">
                    <Button
                        x:Name="OpenImageButton"
                        Height="32"
                        Padding="16,0"
                        MinWidth="136"
                        Click="OnOpenImageClick"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" />
                            <TextBlock Text="选择图片" />
                        </StackPanel>
                    </Button>

                    <!-- 12epx between control and label, etc. -->
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="颜色模式" VerticalAlignment="Center" />
                        <DropDownButton x:Name="ColorModeDropDownButton" MinWidth="140" Height="32">
                            <DropDownButton.Content>
                                <TextBlock x:Name="ColorModeSelectionText" Text="原图" />
                            </DropDownButton.Content>
                            <DropDownButton.Flyout>
                                <MenuFlyout x:Name="ColorModeFlyout" Placement="Bottom" />
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="分量" VerticalAlignment="Center" />
                        <DropDownButton x:Name="ChannelDropDownButton" MinWidth="120" Height="32">
                            <DropDownButton.Content>
                                <TextBlock x:Name="ChannelSelectionText" Text="原图" />
                            </DropDownButton.Content>
                            <DropDownButton.Flyout>
                                <MenuFlyout x:Name="ChannelFlyout" Placement="Bottom" />
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="黑白显示" VerticalAlignment="Center" />
                        <ToggleSwitch
                            x:Name="GrayscaleToggle"
                            Toggled="OnGrayscaleToggled"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <Grid Grid.Row="2">
                <ScrollViewer
                    x:Name="PreviewScrollViewer"
                    ZoomMode="Enabled"
                    IsTabStop="True"
                    IsVerticalScrollChainingEnabled="True"
                    ViewChanged="OnPreviewViewChanged"
                    HorizontalScrollMode="Enabled"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Auto">
                    <Image
                        x:Name="PreviewImage"
                        Stretch="None"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </ScrollViewer>

                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    Visibility="Collapsed"
                    x:Name="PreviewProgressHost">
                    <ProgressBar
                        x:Name="PreviewProgressBar"
                        Grid.Column="0"
                        Height="6"
                        Minimum="0"
                        Maximum="100"
                        Value="0"
                        IsIndeterminate="False"
                        ShowPaused="False"
                        ShowError="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center" />
                </Border>

                <StackPanel
                    x:Name="EmptyStatePanel"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        CornerRadius="42"
                        Background="#FFE5EEF9">
                        <Viewbox Margin="24">
                            <FontIcon Glyph="&#xE91B;" Foreground="#FF335C8A" />
                        </Viewbox>
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="尚未载入图片" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        Opacity="0.74"
                        Text="选择图片后，可切换原图、RGB、HSL、HSV、CMYK、LAB 等模式查看不同分量。" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>