<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="image_channel_viewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:image_channel_viewer"
    mc:Ignorable="d"
    Title="Image Channel Viewer">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF5F7FB" Offset="0.0" />
                <GradientStop Color="#FFE6EEF8" Offset="0.55" />
                <GradientStop Color="#FFF9FBFF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="16" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Button
                        x:Name="OpenImageButton"
                        Height="32"
                        Padding="16,0"
                        MinWidth="136"
                        Click="OnOpenImageClick"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" />
                            <TextBlock Text="选择图片" />
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="颜色模式" VerticalAlignment="Center" />
                        <DropDownButton x:Name="ColorModeDropDownButton" MinWidth="140" Height="32">
                            <DropDownButton.Content>
                                <TextBlock x:Name="ColorModeSelectionText" Text="原图" />
                            </DropDownButton.Content>
                            <DropDownButton.Flyout>
                                <MenuFlyout x:Name="ColorModeFlyout" Placement="Bottom" />
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="分量" VerticalAlignment="Center" />
                        <DropDownButton x:Name="ChannelDropDownButton" MinWidth="120" Height="32">
                            <DropDownButton.Content>
                                <TextBlock x:Name="ChannelSelectionText" Text="原图" />
                            </DropDownButton.Content>
                            <DropDownButton.Flyout>
                                <MenuFlyout x:Name="ChannelFlyout" Placement="Bottom" />
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="黑白显示" VerticalAlignment="Center" />
                        <ToggleSwitch
                            x:Name="GrayscaleToggle"
                            Toggled="OnGrayscaleToggled"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

            </StackPanel>

            <Border Grid.Row="1" Height="1" Background="#220F172A" />

            <Grid Grid.Row="2" Margin="16,12,16,16">
                <ScrollViewer
                    x:Name="PreviewScrollViewer"
                    ZoomMode="Enabled"
                    IsTabStop="True"
                    IsVerticalScrollChainingEnabled="True"
                    ViewChanged="OnPreviewViewChanged"
                    HorizontalScrollMode="Enabled"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Auto">
                    <Image
                        x:Name="PreviewImage"
                        Stretch="None"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top" />
                </ScrollViewer>

                <StackPanel
                    x:Name="EmptyStatePanel"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        CornerRadius="42"
                        Background="#FFE5EEF9">
                        <Viewbox Margin="24">
                            <FontIcon Glyph="&#xEB9F;" Foreground="#FF335C8A" />
                        </Viewbox>
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="尚未载入图片" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        Opacity="0.74"
                        Text="选择图片后，可切换原图、RGB、HSL、HSV、CMYK、LAB 等模式查看不同分量。" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>