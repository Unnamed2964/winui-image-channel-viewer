<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="image_channel_viewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:image_channel_viewer"
    mc:Ignorable="d"
    Title="Image Channel Viewer">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CommandBar
                    Grid.Column="0"
                    IsOpen="False"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <AppBarButton
                        x:Name="OpenImageButton"
                        Label="{x:Bind LocalizedString('OpenImageButton.Label'), Mode=OneWay}"
                        Click="OnOpenImageClick">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8B7;" />
                        </AppBarButton.Icon>
                    </AppBarButton>

                    <AppBarButton
                        x:Name="ColorModeAppBarButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE790;" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <MenuFlyout x:Name="ColorModeFlyout" Placement="Bottom" />
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarButton
                        x:Name="ChannelAppBarButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE8EC;" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <MenuFlyout x:Name="ChannelFlyout" Placement="Bottom" />
                        </AppBarButton.Flyout>
                    </AppBarButton>

                    <AppBarButton
                        x:Name="GrayscaleAppBarButton">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE7A1;" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem
                                    x:Name="ColorDisplayMenuItem"
                                    Text="{x:Bind LocalizedString('ColorDisplayMenuItem.Text'), Mode=OneWay}"
                                    GroupName="PreviewDisplayMode"
                                    IsChecked="True"
                                    Click="OnGrayscaleItemClick" />
                                <RadioMenuFlyoutItem
                                    x:Name="GrayscaleDisplayMenuItem"
                                    Text="{x:Bind LocalizedString('GrayscaleDisplayMenuItem.Text'), Mode=OneWay}"
                                    GroupName="PreviewDisplayMode"
                                    Click="OnGrayscaleItemClick" />
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </CommandBar>

                <CommandBar
                    Grid.Column="1"
                    IsOpen="False"
                    DefaultLabelPosition="Right"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <AppBarButton
                        x:Name="AboutAppBarButton"
                        Label="{x:Bind LocalizedString('AboutAppBarButton.Label'), Mode=OneWay}"
                        Click="OnAboutClick">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE946;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <Grid Grid.Row="2">
                <ScrollViewer
                    x:Name="PreviewScrollViewer"
                    ZoomMode="Enabled"
                    IsTabStop="True"
                    IsVerticalScrollChainingEnabled="True"
                    ViewChanged="OnPreviewViewChanged"
                    HorizontalScrollMode="Enabled"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Auto">
                    <Image
                        x:Name="PreviewImage"
                        Stretch="None"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </ScrollViewer>

                <Border
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    Visibility="Collapsed"
                    x:Name="PreviewProgressHost">
                    <ProgressBar
                        x:Name="PreviewProgressBar"
                        Grid.Column="0"
                        Height="6"
                        Minimum="0"
                        Maximum="100"
                        Value="0"
                        IsIndeterminate="False"
                        ShowPaused="False"
                        ShowError="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center" />
                </Border>

                <StackPanel
                    x:Name="EmptyStatePanel"
                    Spacing="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Border
                        Width="84"
                        Height="84"
                        CornerRadius="42"
                        Background="#FFE5EEF9">
                        <Viewbox Margin="24">
                            <FontIcon Glyph="&#xE91B;" Foreground="#FF335C8A" />
                        </Viewbox>
                    </Border>
                    <TextBlock
                        x:Name="EmptyStateTitle"
                        Text="{x:Bind LocalizedString('EmptyStateTitle.Text'), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="EmptyStateDescription"
                        Text="{x:Bind LocalizedString('EmptyStateDescription.Text'), Mode=OneWay}"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        Opacity="0.74" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>